# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv file
.env

# Personal overrides for env files (e.g. with PRIVATE_KEY filled in).
# Create script/env/sepolia.env.local etc. for local secrets — never commit.
script/env/*.env.local

# Coverage Reports
lcov.info
