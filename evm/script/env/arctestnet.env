# ============================================================
# Chainbills — Arc Testnet
# CAIP-2: eip155:5042002
# Wormhole chain ID: — (not deployed)   Circle domain: 10
# ============================================================

# --- Wallet --------------------------------------------------
# Your deployer private key — NEVER commit this value.
PRIVATE_KEY=

# --- RPC -----------------------------------------------------
RPC_URL=https://rpc.testnet.arc.network

# --- This chain's Chainbills proxy (fill after first deploy) -
CB_ADDRESS=0x92e67Bfe49466b18ccDF2A3A28B234AB68374c60

# cbChainId = keccak256("eip155:5042002")
# Run: ./script/run.sh arc ComputeCbChainId
CAIP2=eip155:5042002
CB_CHAIN_ID=

# --- Wormhole ------------------------------------------------
# Wormhole is NOT deployed on Arc. Use SetupCCTPOnly instead.
# Leave these blank if running SetupCCTPOnly.
WORMHOLE_ADDRESS=
WORMHOLE_CHAIN_ID=
WORMHOLE_FINALITY=

# --- Circle CCTP (Arc native) --------------------------------
# Arc uses SetupCCTPOnly — no Wormhole bridge, CCTP-only messaging.
CIRCLE_TRANSMITTER_ADDRESS=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
CIRCLE_BRIDGE_ADDRESS=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
CIRCLE_DOMAIN=10

# --- USDC on Arc ---------------------------------------------
# USDC is the native gas token on Arc. ERC-20 interface address:
USDC_ADDRESS=0x3600000000000000000000000000000000000000
