# ============================================================
# Chainbills — MegaETH Mainnet
# CAIP-2: eip155:4326
# Wormhole chain ID: (verify in Wormhole docs)
# Circle CCTP: NOT deployed on MegaETH as of May 2026
# ============================================================

# --- Wallet --------------------------------------------------
# Your deployer private key — NEVER commit this value.
PRIVATE_KEY=

# --- RPC -----------------------------------------------------
RPC_URL=https://mainnet.megaeth.com/rpc

# --- Fee Config ----------------------------------------------
FEE_COLLECTOR=
FEE_PERCENT=200
ADMIN_WALLET=

# --- Verification --------------------------------------------
VERIFY=true
VERIFIER=blockscout
VERIFIER_URL=https://explorer.megaeth.com/api/
SKIP_SIMULATION=true

# --- This chain's Chainbills proxy (fill after first deploy) -
CB_ADDRESS=

# cbChainId = keccak256("eip155:4326")
# Run: ./script/run.sh megaeth ComputeCbChainId
CAIP2=eip155:4326
CB_CHAIN_ID=0x78b4988135f242a792c3ba307a59ea12c5ec8c24390a1f41381eeb7c7c444d3a

# --- Wormhole ------------------------------------------------
# Wormhole IS deployed on MegaETH mainnet.
# Verify the exact chain ID at: https://wormhole.com/docs/products/reference/chain-ids/
WORMHOLE_ADDRESS=0x3D5c2c2BEA15Af5D45F084834c535628C48c42A4
WORMHOLE_CHAIN_ID=64    
WORMHOLE_FINALITY=1

# --- Circle CCTP ---------------------------------------------
# Circle CCTP is NOT deployed on MegaETH mainnet as of May 2026.
# Use SetupWormholeAndCircle only when/if Circle adds MegaETH.
# Monitor: https://developers.circle.com/stablecoins/docs/cctp-supported-blockchains
CIRCLE_BRIDGE_ADDRESS=
CIRCLE_TRANSMITTER_ADDRESS=
CIRCLE_DOMAIN=

# --- USDC on MegaETH -----------------------------------------
# No native USDC via CCTP yet. Fill when Circle deploys.
USDC_ADDRESS=

# ============================================================
# Cross-chain registration: not applicable until CCTP is live.
# ============================================================
