# --- This chain's Chainbills proxy (fill after first deploy) -
CB_ADDRESS=0x92e67Bfe49466b18ccDF2A3A28B234AB68374c60

# cbChainId = keccak256("eip155:11155111")
# Run: ./script/run.sh sepolia ComputeCbChainId
CAIP2=eip155:11155111
CB_CHAIN_ID=0xafa90c317deacd3d68f330a30f96e4fa7736e35e8d1426b2e1b2c04bce1c2fb7

# --- Wormhole ------------------------------------------------
WORMHOLE_ADDRESS=0x4a8bc80Ed5a4067f1CCf107057b8270E0cC11A78
WORMHOLE_CHAIN_ID=10002
# 1 = Finalized on Sepolia
WORMHOLE_FINALITY=1

