# ──────────────────────────────────────────────────────────────────────────────
# Chainbills Relayer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Relayer Wallet ─────────────────────────────────────────────────────────────
# A single EVM private key used to sign transactions on ALL chains.
# This wallet MUST hold:
#   - Native gas on every destination chain (ETH on Sepolia, USDC on Arc Testnet)
#   - ADMIN_ROLE on every Chainbills proxy (granted via grantAdminRole())
RELAYER_PRIVATE_KEY=0x...

# ── Firebase / Firestore ───────────────────────────────────────────────────────
# Path to your Google Cloud service account JSON key.
# In production on Cloud Run, this is not needed as the default service account is used if deployed in Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=./lib/google-service-account.json


# ── RPC Endpoints ─────────────────────────────────────────────────────────────
# Use a dedicated node (Alchemy / Infura / QuickNode) in production.
# Public RPCs are fine for testing but will be rate-limited.
RPC_ARC_TESTNET=https://rpc.testnet.arc.network
RPC_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
RPC_MEGAETH=https://mainnet.megaeth.com/rpc

# ── Polling ────────────────────────────────────────────────────────────────────
# How often (in ms) to poll each chain for new events via getLogs.
# Arc Testnet has ~500ms blocks so 2s is fine; Sepolia has ~12s blocks.
# This is a global default; per-chain overrides are in src/chains/index.ts.
POLL_INTERVAL_MS=12000

