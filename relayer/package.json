{
  "name": "@chainbills/relayer",
  "version": "1.0.0",
  "description": "Chainbills EVM cross-chain relayer — listens to contract events, relays Wormhole VAAs and Circle CCTP attestations, and indexes entities into Firestore.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "backfill": "tsx src/scripts/backfill.ts",
    "check-pending": "tsx src/scripts/check-pending.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@wormhole-foundation/sdk": "^1.0.0",
    "@wormhole-foundation/sdk-evm": "^1.0.0",
    "firebase-admin": "^12.1.1",
    "viem": "^2.21.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.15.0",
    "@types/node": "^20.14.0"
  },
  "private": true
}
